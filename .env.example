# Copia este archivo a ".env" y rellena los valores de tu proyecto Supabase.
# Los encuentras en: Supabase → Project Settings → Data API / API Keys
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave PUBLISHABLE (empieza con "sb_publishable_"). Es segura para el navegador.
# NO uses la SECRET KEY aquí: expondría tu base de datos a cualquiera.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu-clave

# Moneda para mostrar precios (código ISO 4217). Ej: USD, CRC, MXN, COP, CLP
VITE_CURRENCY=USD
VITE_LOCALE=es-CR

# Nombre de tu empresa (aparece en el mensaje de cobro de WhatsApp)
VITE_COMPANY_NAME=Distribuidora de Agua
